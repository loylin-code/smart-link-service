# Application
APP_NAME=SmartLink
APP_ENV=development
DEBUG=true
VERSION=1.0.0
API_BASE_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database
# For development (SQLite): DATABASE_TYPE=sqlite
# For production (PostgreSQL): DATABASE_TYPE=postgresql
DATABASE_TYPE=sqlite
SQLITE_DB_FILE=smartlink.db

# PostgreSQL settings (only needed when DATABASE_TYPE=postgresql)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartlink
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=smartlink
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Security
API_KEY_HEADER=X-API-Key
MASTER_API_KEY=sk-smartlink-master-key-change-in-production
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# JWT Settings
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# OAuth2 Callback Configuration
OAUTH_CALLBACK_BASE_URL=http://localhost:8000/api/v1/auth/oauth
FRONTEND_URL=http://localhost:5173

# OAuth2 Security Settings
OAUTH_STATE_EXPIRE_MINUTES=10
OAUTH_CLIENT_DEFAULT_EXPIRE_DAYS=365

# LLM - OpenAI-compatible API
# Works with: OpenAI, Bailian, DeepSeek, vLLM, Ollama, etc.
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1  # Or custom: https://coding.dashscope.aliyuncs.com/v1
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# MCP
MCP_SERVERS_DIR=./mcp_servers

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_DAY=100000

# Session
SESSION_EXPIRE_SECONDS=86400

# Lane Concurrency
MAX_CONCURRENT_LANES_PER_USER=3

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json